@page "/"

<PageTitle>Telemetry Dashboard</PageTitle>


<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="scada-container pa-2" Style="padding: 0;">
    <MudPaper Class="mb-2 pa-1 scada-panel" Elevation="0" Style="background-color: var(--mud-palette-surface);">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold" Color="Color.Primary">TELEMETRY DASHBOARD</MudText>
                <MudChip T="string" Color="@(_isConnected ? Color.Secondary : Color.Error)" Size="Size.Small" Variant="Variant.Text" Label="true">
                    WEBSOCKET STATUS: @(_hubConnection?.State.ToString().ToUpper() ?? "DISCONNECTED")
                </MudChip>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudText Typo="Typo.caption" Class="text-secondary">BURST FRAMES: <strong>@_totalFramesIngested.ToString("N0")</strong></MudText>
                <MudText Typo="Typo.caption" Class="text-secondary">SYS CLOCK: <strong>@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss UTC")</strong></MudText>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="1">
        <MudItem xs="12" md="4">
            <MudGrid Spacing="1">
                @foreach (var machine in _machines.Values)
                {
                    <MudItem xs="6" sm="4" md="6">
                        <MudCard Class="scada-panel">
                            <MudCardContent>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                    <MudText Typo="Typo.caption" Class="font-weight-bold">@machine.Id</MudText>
                                    <div style="width: 8px; height: 8px; border-radius: 50%; background-color: @(machine.Status.GetStatusHex());"></div>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Baseline">
                                    <MudText Typo="Typo.h6" Style="font-size: 1.1rem; font-weight: 700;">
                                        @machine.CoreTemperature.ToString("F1")<span style="font-size: 0.7rem; color: #8B949E; margin-left: 2px;">°C</span>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="@(machine.Status.GetStatusColor())">@machine.Status.ToUpper()</MudText>
                                </MudStack>
                                <div class="mt-1">
                                    <MudProgressLinear Color="@(machine.Status.GetStatusColor())" Value="@machine.PressurePercentage" Style="height: 3px;" Max="100" />
                                </div>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudCard Class="scada-panel mb-2 d-flex flex-column" Style="min-height: 300px;">
                <MudCardContent Class="d-flex flex-column flex-grow-1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.caption" Class="font-weight-bold">AVERAGE TEMPERATURE TREND</MudText>
                        <MudChip T="string" Color="@(_isConnected ? Color.Primary : Color.Error)" Size="Size.Small" Variant="Variant.Outlined">
                            @(_isConnected ? "WS PIPELINE OPEN" : "WS PIPELINE CLOSED")
                        </MudChip>
                    </MudStack>

                    @{
                        var sparklineData = _sparklineStream.ToArray();
                        var currentVal = sparklineData.Any() ? sparklineData.LastOrDefault() : 0;
                        var peakVal = sparklineData.Any() ? sparklineData.Max() : 0;
                        var avgVal = sparklineData.Any() ? sparklineData.Average() : 0;
                    }

                    <MudStack Row="true" Spacing="4" Class="mb-2">
                        <MudStack Spacing="2" Style="min-width: 120px;">
                            <MudPaper Elevation="0" Class="pa-2 d-flex flex-column align-center" Style="background: rgba(255,255,255,0.05);">
                                <MudText Typo="Typo.caption" Class="text-secondary">CURRENT AVG</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Primary">@currentVal.ToString("F1")<span style="font-size: 0.7rem; color: #8B949E; margin-left: 2px;">°C</span></MudText>
                            </MudPaper>
                            <MudPaper Elevation="0" Class="pa-2 d-flex flex-column align-center" Style="background: rgba(255,255,255,0.05);">
                                <MudText Typo="Typo.caption" Class="text-secondary">PEAK</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Success">@peakVal.ToString("F1")<span style="font-size: 0.7rem; color: #8B949E; margin-left: 2px;">°C</span></MudText>
                            </MudPaper>
                            <MudPaper Elevation="0" Class="pa-2 d-flex flex-column align-center" Style="background: rgba(255,255,255,0.05);">
                                <MudText Typo="Typo.caption" Class="text-secondary">OVERALL AVG</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Info">@avgVal.ToString("F1")<span style="font-size: 0.7rem; color: #8B949E; margin-left: 2px;">°C</span></MudText>
                            </MudPaper>
                        </MudStack>

                        <div class="flex-grow-1 d-flex align-center" style="min-height: 180px;">
                            <MudChart ChartType="ChartType.Line" 
                                      ChartSeries="@(new List<ChartSeries>() { new ChartSeries { Name="Average Temp", Data = sparklineData } })" 
                                      ChartOptions="@(new ChartOptions { YAxisLines = true, XAxisLines = false })" 
                                      Width="100%" 
                                      Height="234px" />
                        </div>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12">
            <MudCard Class="scada-panel">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="px-3 py-1" Style="background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--mud-palette-lines-default);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.caption" Class="font-weight-bold" Color="Color.Primary">NETWORK INGRESS LOG</MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Class="text-secondary" Style="font-size: 0.65rem;">/dev/tty0</MudText>
                </MudStack>
                <div class="scada-terminal pa-2" style="height: 160px; overflow-y: auto;">
                    @for (int i = 0; i < _terminalFrames.Count; i++)
                    {
                        var frame = _terminalFrames[i];
                        var pkgNumber = _totalFramesIngested - i;
                        var maxMetric = frame.Metrics.Any() ? frame.Metrics.MaxBy(m => m.CoreTemperature) : null;
                        
                        <MudStack Row="true" Spacing="4" Class="scada-terminal-line">
                            <span style="color: var(--mud-palette-info);">[@frame.Timestamp.ToString("HH:mm:ss.fff")]</span>
                            <span style="color: var(--mud-palette-warning); width: 180px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;" title="@frame.FrameHex">@frame.FrameHex</span>
                            <span style="color: var(--mud-palette-success);">
                                // BINDED: PKG_SEQ #@pkgNumber.ToString("D6")
                                @if (maxMetric != null)
                                {
                                    <span style="color: var(--mud-palette-text-secondary); margin-left: 8px;">[MAX: @maxMetric.CoreTemperature.ToString("F1")°C @@ @maxMetric.Id]</span>
                                }
                            </span>
                        </MudStack>
                    }
                </div>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

